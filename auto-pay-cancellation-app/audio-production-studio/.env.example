# Audio Production Studio Environment Configuration

# Server
NODE_ENV=development
PORT=3000

# ElevenLabs API (Required)
# Get key from: https://elevenlabs.io
ELEVENLABS_API_KEY=sk_your_key_here

# Kits.ai API (Optional for voice blending)
# Get key from: https://kits.ai
KITSAI_API_KEY=your_kitsai_key_here

# Frontend API URL
VITE_API_URL=http://localhost:3000
