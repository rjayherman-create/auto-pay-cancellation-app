{
  "name": "animation-studio",
  "version": "1.0.0",
  "description": "Professional Animation & Video Production Studio",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "npm run backend:dev",
    "backend:dev": "nodemon --exec \"node --input-type=module --eval \\\"process.env.PORT=5001; await import('./backend/server.js')\\\"\" ",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "build": "npm run frontend:build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.0.3",
    "node-fetch": "^3.3.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "concurrently": "^7.5.0"
  }
}
